# =============================================================================
# Margin Invest API — Production Environment Variables (Railway)
# =============================================================================
# All variables use the MARGIN_ prefix (from pydantic-settings config).
# Copy this to your Railway service's environment variables.

# --- Database (Railway PostgreSQL) ---
# Use Railway's INTERNAL connection string, converted to asyncpg format.
# Railway gives:  postgresql://user:pass@host:port/railway
# You need:       postgresql+asyncpg://user:pass@host:port/railway?sslmode=require
MARGIN_DATABASE_URL=postgresql+asyncpg://user:password@host:port/railway?sslmode=require

# --- Connection Pool (defaults are production-safe, override if needed) ---
# MARGIN_DB_POOL_SIZE=5
# MARGIN_DB_MAX_OVERFLOW=10
# MARGIN_DB_POOL_TIMEOUT=30
# MARGIN_DB_POOL_RECYCLE=1800
# MARGIN_DB_POOL_PRE_PING=true

# --- Redis (Railway Redis) ---
# Use Railway's INTERNAL Redis URL.
MARGIN_REDIS_URL=redis://default:password@host:port

# --- Environment ---
# Must be "production" — this activates the localhost DB guard.
MARGIN_ENVIRONMENT=production

# --- CORS ---
# JSON array of allowed frontend origins. Set to your Vercel deployment URL.
MARGIN_CORS_ORIGINS=["https://your-app.vercel.app"]

# --- Auth / JWT ---
# Generate: openssl rand -hex 32
MARGIN_JWT_SECRET=
MARGIN_JWT_ALGORITHM=HS256

# --- MFA Encryption ---
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MARGIN_MFA_ENCRYPTION_KEY=

# --- WebAuthn / Passkeys ---
MARGIN_WEBAUTHN_RP_ID=your-app.vercel.app
MARGIN_WEBAUTHN_RP_NAME=Margin Invest
MARGIN_WEBAUTHN_RP_ORIGIN=https://your-app.vercel.app

# --- API Key Encryption ---
# Generate Fernet key (same method as MFA key, but use a DIFFERENT key).
MARGIN_API_KEY_ENCRYPTION_KEY=

# --- Stripe (optional — leave blank to disable billing) ---
MARGIN_STRIPE_SECRET_KEY=
MARGIN_STRIPE_PUBLISHABLE_KEY=
MARGIN_STRIPE_WEBHOOK_SECRET=
MARGIN_STRIPE_PORTFOLIO_PRICE_ID=
MARGIN_STRIPE_INSTITUTIONAL_PRICE_ID=

# --- Debug (leave false in production) ---
MARGIN_DEBUG=false
