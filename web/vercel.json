{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "margin-invest.vercel.app" }],
      "destination": "https://margin-invest.com/$1",
      "permanent": true
    }
  ]
}
